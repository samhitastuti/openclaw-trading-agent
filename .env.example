# ========================================
# Alpaca API Credentials
# ========================================
# Get your paper-trading keys at https://app.alpaca.markets → Account → API Keys
# Paper trading is free and uses simulated funds – safe for testing.
# Without these, market-data/account/positions endpoints return demo responses.
ALPACA_API_KEY=replace_with_api_key
ALPACA_SECRET_KEY=replace_With_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ========================================
# Ollama (optional – free local AI via Mistral)
# ========================================
# Set USE_OLLAMA=true to force Ollama, USE_OLLAMA=false to disable it.
# Default "auto" probes http://localhost:11434 – uses Ollama when running.
USE_OLLAMA=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral


# Without this, the server uses a local NLP fallback (regex-based).
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ========================================
# Server Configuration
# ========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ========================================
# Frontend (Vite)
# ========================================
# Vite loads these from the REPO ROOT (parent of frontend/) — same file as backend vars is OK.
#
# In `npm run dev`, VITE_API_URL is IGNORED unless you set VITE_DIRECT_API=true.
# The UI then calls /api on port 3000 and Vite proxies to FastAPI (default http://127.0.0.1:8000).
#
# Optional: call the API directly from the browser in dev (CORS must allow your origin).
# VITE_DIRECT_API=true
# VITE_API_URL=http://127.0.0.1:8000
#
# Optional: proxy target if the API is not on 127.0.0.1:8000.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
#
# Production build: set the real API origin (VITE_DIRECT_API is not used the same way).
# VITE_API_URL=https://your-api.example.com

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO

# ========================================
# Audit & File Access
# ========================================
AUDIT_LOG_FILE=audit_trail.jsonl
ALLOWED_OUTPUT_DIR=outputs/

# ========================================
# Veridict auth (SQLite + JWT)
# ========================================
# SQLite file for users table (login / sign-up). Override to use an absolute path.
# DATABASE_PATH=backend/data/veridict_users.db
# Strong secret for signing JWTs (generate e.g. openssl rand -hex 32)
AUTH_JWT_SECRET=replace_with_a_long_random_string
# Token lifetime in hours (default 7 days)
# AUTH_JWT_EXPIRE_HOURS=168
