# ========================================
# Alpaca API Credentials
# ========================================
# Get your paper-trading keys at https://app.alpaca.markets → Account → API Keys
# Paper trading is free and uses simulated funds – safe for testing.
# Without these, market-data/account/positions endpoints return demo responses.
ALPACA_API_KEY=your_paper_trading_key_here
ALPACA_SECRET_KEY=your_paper_trading_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ========================================
# OpenAI API Key (optional – enables AI intent classification)
# ========================================
# Without this, the server uses a local NLP fallback (regex-based).
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# Server Configuration
# ========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ========================================
# Frontend (Vite)
# ========================================
# URL the React frontend uses to reach the FastAPI backend.
VITE_API_URL=http://localhost:8000

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO

# ========================================
# Audit & File Access
# ========================================
AUDIT_LOG_FILE=audit_trail.jsonl
ALLOWED_OUTPUT_DIR=outputs/

# ========================================
# Veridict auth (SQLite + JWT)
# ========================================
# SQLite file for users table (login / sign-up). Override to use an absolute path.
# DATABASE_PATH=backend/data/veridict_users.db
# Strong secret for signing JWTs (generate e.g. openssl rand -hex 32)
AUTH_JWT_SECRET=replace_with_a_long_random_string
# Token lifetime in hours (default 7 days)
# AUTH_JWT_EXPIRE_HOURS=168
